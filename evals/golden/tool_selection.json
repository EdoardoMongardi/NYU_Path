            "userMessage": "Am I on track to graduate on time?",
            "expectedToolName": "run_full_audit",
            "expectedArgsShape": {
                "type": "object",
                "properties": {
                    "programFilter": {
                        "type": "string",
                        "optional": true
                    }
                },
                "_note": "Counter-case: 'on track' is a degree-progress claim — System Prompt Rule §17 forbids the LLM from saying 'all requirements met' without a fresh run_full_audit. The model must call run_full_audit (NOT answer from session memory or training data)."
            }
