        {
            "id": "tool-003-current-gpa-not-synthesized",
            "userMessage": "What is my current cumulative GPA?",
            "expectedToolName": "run_full_audit",
            "expectedArgsShape": {
                "type": "object",
                "properties": {
                    "programFilter": {
                        "type": "string",
                        "optional": true
                    }
                },
                "_note": "Per Cardinal Rule §2.1, GPA must come from a tool. run_full_audit returns cumulativeGPA in its summarizeResult. Some implementations also expose get_academic_standing — but the agent must NOT synthesize a GPA from training data or context. Counter-case for tool-skip behavior."
            }
        },
