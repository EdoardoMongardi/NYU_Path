    "cases": [
        {
            "id": "tool-001-audit-progress-question",
            "userMessage": "How far along am I in my degree, and what's still standing between me and graduation?",
            "expectedToolName": "run_full_audit",
            "expectedArgsShape": {
                "type": "object",
                "properties": {
                    "programFilter": {
                        "type": "string",
                        "optional": true
                    }
                }
            }
        },
        {
            "id": "tool-002-audit-remaining-requirements",
